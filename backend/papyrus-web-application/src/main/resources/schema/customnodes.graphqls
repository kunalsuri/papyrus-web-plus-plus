extend union INodeStyle = PackageNodeStyle

type PackageNodeStyle {
  borderColor: String!
  borderSize: Int!
  borderStyle: LineStyle!
  background: String!
}

extend union INodeStyle = RectangleWithExternalLabelNodeStyle

type RectangleWithExternalLabelNodeStyle {
  borderColor: String!
  borderSize: Int!
  borderStyle: LineStyle!
  background: String!
}

extend union INodeStyle = ImageWithTopLabelNodeStyle

type ImageWithTopLabelNodeStyle {
  borderColor: String!
  borderSize: Int!
  borderStyle: LineStyle!
  imageURL: String!
}

extend union INodeStyle = NoteNodeStyle

type NoteNodeStyle {
  background: String!
  borderColor: String!
  borderSize: Int!
  borderStyle: LineStyle!
}

extend union INodeStyle = InnerFlagNodeStyle

type InnerFlagNodeStyle {
  background: String!
	borderColor: String!
	borderSize: Int!
	borderStyle: LineStyle!
}

extend union INodeStyle = OuterFlagNodeStyle

type OuterFlagNodeStyle {
  background: String!
	borderColor: String!
	borderSize: Int!
	borderStyle: LineStyle!
}

extend union INodeStyle = CuboidNodeStyle

type CuboidNodeStyle {
  background: String!
	borderColor: String!
	borderSize: Int!
	borderStyle: LineStyle!
}

extend union INodeStyle = CustomImageNodeStyle

type CustomImageNodeStyle {
	shape: String!
  	background: String!
	borderColor: String!
	borderSize: Int!
	borderStyle: LineStyle!
}
